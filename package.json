{
  "name": "forgerise",
  "private": true,
  "version": "0.0.0",
  "description": "ForgeRise — Ops Intelligence for Coaches",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter ./web build",
    "lint": "pnpm -r --filter ./web lint",
    "typecheck": "pnpm -r --filter ./web typecheck",
    "test": "pnpm -r --filter ./web test"
  },
  "pnpm": {
    "overrides": {
      "cross-spawn": ">=7.0.6",
      "picomatch": ">=4.0.4",
      "glob": ">=10.5.0"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-h25m-26qc-wcjf",
        "GHSA-q4gf-8mx6-v5v3"
      ]
    }
  }
}
