# API environment example
# Copy to api/.env for local dev. NEVER commit real values. K8s secrets in prod.

# --- ASP.NET ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5080

# --- Database (PostgreSQL) ---
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=forgerise;Username=forgerise;Password=forgerise

# --- Auth (Phase 2) ---
Jwt__Issuer=forgerise
Jwt__Audience=forgerise.web
Jwt__Key=REPLACE_WITH_AT_LEAST_32_CHARS_OF_RANDOM_DATA

# --- AI provider abstraction (Phase 4) ---
Ai__Provider=openai            # openai | azure-openai | mock
Ai__OpenAi__ApiKey=
Ai__AzureOpenAi__Endpoint=
Ai__AzureOpenAi__ApiKey=
Ai__AzureOpenAi__Deployment=

# --- Observability ---
OTEL_SERVICE_NAME=forgerise-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
Logging__LogLevel__Default=Information

# --- CORS (locked per environment) ---
Cors__AllowedOrigins=http://localhost:3000
