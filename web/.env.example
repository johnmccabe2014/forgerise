# Web environment example
# Copy to web/.env.local for development. NEVER commit real values.

# Public — exposed to the browser. Treat as not-secret.
NEXT_PUBLIC_APP_NAME=ForgeRise
NEXT_PUBLIC_API_BASE_URL=http://localhost:5080

# Server-only — never prefix with NEXT_PUBLIC_.
# OTel — exports to the on-server Grafana/OTel collector.
OTEL_SERVICE_NAME=forgerise-web
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Logging
LOG_LEVEL=info
